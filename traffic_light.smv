MODULE main
VAR
    light: {red, yellow, green};
ASSIGN
    init(light) := red;
    next(light) :=
        case
            light = red : green;
            light  = green : yellow;
            light = yellow : red;
        esac;

--Adding rules
--Safety Property (LTL)
LTLSPEC G !(light = green & X light = green)

--Liveness Property (LTL)
LTLSPEC F light = green

--Transition Property
LTLSPEC G (light = green -> X light = yellow)

